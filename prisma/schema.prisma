generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  avatar        String?  // Google profile picture
  googleId      String   @unique
  refreshToken  String?  // Hashed refresh token
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  projects      Project[]
  tasks         Task[]
  notes         Note[]
  quickCaptures QuickCapture[]
  dailyPlans    DailyPlan[]
  moodLogs      MoodLog[]
  notifications Notification[]
  aiSuggestions AISuggestion[]
  preferences   UserPreference?
  activityLogs  ActivityLog[]
}

model Project {
  id          String        @id @default(cuid())
  title       String
  description String?
  status      ProjectStatus @default(PLANNING)
  priority    Priority      @default(MEDIUM)
  deadline    DateTime?
  tags        String[]      @default([])
  userId      String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user  User   @relation(fields: [userId], references: [id])
  tasks Task[]
  notes Note[]
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  deadline    DateTime?
  estimate    Int?       // minutes
  tags        String[]   @default([])
  projectId   String?
  userId      String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  project  Project?  @relation(fields: [projectId], references: [id])
  reminder Reminder?
}

model Note {
  id        String     @id @default(cuid())
  title     String
  content   String
  tags      String[]   @default([])
  source    NoteSource @default(MANUAL)
  projectId String?
  userId    String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])
}

model QuickCapture {
  id        String   @id @default(cuid())
  rawInput  String
  processed Boolean  @default(false)
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model DailyPlan {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  plan      Json     // Structured plan from AI
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model MoodLog {
  id        String      @id @default(cuid())
  energy    EnergyLevel
  mood      MoodType
  userId    String
  createdAt DateTime    @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Reminder {
  id       String   @id @default(cuid())
  time     DateTime
  taskId   String   @unique
  sent     Boolean  @default(false)

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  read      Boolean  @default(false)
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model AISuggestion {
  id        String         @id @default(cuid())
  type      SuggestionType
  content   Json
  userId    String
  createdAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id])
}

model UserPreference {
  id       String  @id @default(cuid())
  language String  @default("en")
  theme    String  @default("system")
  userId   String  @unique

  user User @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum NoteSource {
  MANUAL
  QUICK_CAPTURE
  AI_GENERATED
}

enum EnergyLevel {
  LOW
  MEDIUM
  HIGH
}

enum MoodType {
  CALM
  NEUTRAL
  TIRED
  STRESSED
  FOCUSED
}

enum SuggestionType {
  PRIORITY
  DAILY_PLAN
  NEXT_ACTION
  QUICK_CAPTURE
  OVERLOAD
}
